# Игнорировать папки сборки (общие названия)
build/
cmake-build-*/
out/

# Игнорировать временные файлы CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# Игнорировать сгенерированные файлы и артефакты
*.o
*.obj
*.exe
*.out
*.app
*.dll
*.so
*.dylib
*.a
*.lib

# Игнорировать файлы IDE (опционально, но обычно полезно)
.vscode/
.idea/
*.swp
*.swo
*~

# Игнорировать всё, кроме .h, .cpp и файлов CMake
# Если нужно строго исключить всё, кроме указанных типов, раскомментируй следующие строки:
# *
# !*/
# !*.h
# !*.cpp
# !CMakeLists.txt
# !*.cmake